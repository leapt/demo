{
    "type": "project",
    "license": "proprietary",
    "prefer-stable": true,
    "require": {
        "php": ">=8.4.0",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "doctrine/doctrine-bundle": "^3.2.2",
        "doctrine/doctrine-migrations-bundle": "^4.0.0",
        "doctrine/orm": "^3.6.2",
        "league/flysystem-async-aws-s3": "^3.31.0",
        "league/flysystem-aws-s3-v3": "^3.32.0",
        "league/flysystem-bundle": "^3.6.2",
        "leapt/core-bundle": "^6.0.0",
        "leapt/froala-editor-bundle": "^1.8.0",
        "leapt/slug-type-bundle": "^1.4",
        "symfony/asset": "8.0.*",
        "symfony/asset-mapper": "8.0.*",
        "symfony/console": "8.0.*",
        "symfony/dotenv": "8.0.*",
        "symfony/flex": "^2.10.0",
        "symfony/framework-bundle": "8.0.*",
        "symfony/runtime": "8.0.*",
        "symfony/stimulus-bundle": "^2.32.0",
        "symfony/twig-bundle": "8.0.*",
        "symfony/yaml": "8.0.*",
        "twig/extra-bundle": "^3.23.0",
        "twig/twig": "^3.23.0"
    },
    "require-dev": {
        "kocal/biome-js-bundle": "^2.1.2",
        "phpstan/extension-installer": "^1.4.3",
        "phpstan/phpstan": "^2.1.40",
        "phpstan/phpstan-deprecation-rules": "^2.0.4",
        "phpstan/phpstan-doctrine": "^2.0.18",
        "phpstan/phpstan-symfony": "^2.0.15",
        "phpunit/phpunit": "^13.0.5",
        "symfony/browser-kit": "8.0.*",
        "symfony/css-selector": "8.0.*",
        "symfony/debug-bundle": "8.0.*",
        "symfony/maker-bundle": "^1.66.0",
        "symfony/monolog-bundle": "^4.0.1",
        "symfony/stopwatch": "8.0.*",
        "symfony/web-profiler-bundle": "8.0.*",
        "symplify/easy-coding-standard": "^13.0.4",
        "vincentlanglet/twig-cs-fixer": "^3.14",
        "zenstruck/foundry": "^2.9.2"
    },
    "config": {
        "allow-plugins": {
            "symfony/flex": true,
            "symfony/runtime": true,
            "phpstan/extension-installer": true
        },
        "bump-after-update": true,
        "preferred-install": {
            "*": "dist"
        },
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*",
        "symfony/polyfill-php82": "*"
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "importmap:install": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd",
            "froala:install": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ]
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "8.0.*"
        }
    }
}
